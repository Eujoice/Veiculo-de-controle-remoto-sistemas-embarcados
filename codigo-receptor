#include <VirtualWire.h>
#include <Servo.h>

// Pinos Receptor e Atuadores
const int PIN_RX = 11;
const int PIN_LED = 3;      // Farol
const int PIN_SERVO = 9;    // Direção
const int PIN_IN1 = 5;      // Ponte H - Sentido 1
const int PIN_IN2 = 6;      // Ponte H - Sentido 2

Servo meuServo;

struct PacoteDados {
  int eixoX;
  int eixoY;
  bool botao;
};

PacoteDados dados;

void setup() {
  pinMode(PIN_LED, OUTPUT);
  pinMode(PIN_IN1, OUTPUT);
  pinMode(PIN_IN2, OUTPUT);
  
  meuServo.attach(PIN_SERVO);
  
  vw_set_rx_pin(PIN_RX);
  vw_setup(2000);
  vw_rx_start();
}

void loop() {
  uint8_t buf[sizeof(dados)];
  uint8_t buflen = sizeof(dados);

  if (vw_get_message(buf, &buflen)) {
    memcpy(&dados, buf, sizeof(dados));

    // 1. Controle do Farol
    digitalWrite(PIN_LED, dados.botao ? HIGH : LOW);

    // 2. Controle de Direção (Servo)
    // Mapeia 0-1023 para 45º à esquerda (45) e 45º à direita (135)
    // O centro do servo é 90º.
    int angulo = map(dados.eixoX, 0, 1023, 45, 135);
    meuServo.write(angulo);

    // 3. Controle de Tração (Motor CC)
    // Joystick parado em ~512. Acima = Horário, Abaixo = Anti-horário.
    if (dados.eixoY > 540) { // Para cima (Horário)
      int vel = map(dados.eixoY, 541, 1023, 0, 255);
      analogWrite(PIN_IN1, vel);
      digitalWrite(PIN_IN2, LOW);
    } 
    else if (dados.eixoY < 480) { // Para baixo (Anti-horário)
      int vel = map(dados.eixoY, 479, 0, 0, 255);
      digitalWrite(PIN_IN1, LOW);
      analogWrite(PIN_IN2, vel);
    } 
    else { // Zona morta (Parado)
      digitalWrite(PIN_IN1, LOW);
      digitalWrite(PIN_IN2, LOW);
    }
  }
}
